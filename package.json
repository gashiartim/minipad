{
  "name": "minipad",
  "version": "1.0.0",
  "description": "Local-first web notepad with real-time tab sync, rich text, and optional note passwords — Next.js, Prisma, Socket.io",
  "private": false,
  "author": {
    "name": "Artim Gashi",
    "email": "artimgashi.dev@gmail.com",
    "url": "https://github.com/gashiartim"
  },
  "license": "MIT",
  "homepage": "https://minipad.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gashiartim/minipad.git"
  },
  "bugs": {
    "url": "https://github.com/gashiartim/minipad/issues"
  },
  "keywords": [
    "notepad",
    "notes",
    "nextjs",
    "self-hosted",
    "socket-io",
    "prisma",
    "sqlite",
    "rich-text-editor",
    "local-first"
  ],
  "scripts": {
    "build": "next build",
    "dev": "node server.js",
    "dev:next": "next dev",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "start": "node server.js",
    "start:next": "next start",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "backup": "tsx scripts/backup-database.ts",
    "restore": "tsx scripts/restore-database.ts",
    "export": "tsx scripts/export-notes.ts",
    "cleanup": "tsx scripts/cleanup-orphaned-images.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:logs": "docker-compose logs -f app",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
