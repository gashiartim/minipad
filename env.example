# Database Configuration
# For local development with SQLite:
DATABASE_URL="file:./data/app.db"

# For production with PostgreSQL (uncomment and update):
# DATABASE_URL="postgresql://postgres:your_password@localhost:5432/notepad"

# For Docker Compose PostgreSQL:
# DATABASE_URL="postgresql://postgres:postgres@db:5432/notepad"

# PostgreSQL password for Docker Compose
POSTGRES_PASSWORD="postgres"

# Node environment
NODE_ENV="development"

# Optional: Add any other environment variables your app needs
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="https://yourdomain.com"
