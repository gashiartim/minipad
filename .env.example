# ------------------------------------------------------------------------------
# MiniPad environment (copy to .env and adjust). Never commit .env.
# ------------------------------------------------------------------------------

# --- Database ---
# Local development (SQLite file next to prisma/ or under data/)
DATABASE_URL="file:./data/app.db"

# Docker / production Postgres (leave unused for SQLite-only dev)
# DATABASE_URL="postgresql://postgres:your_password@localhost:5432/notepad"
# POSTGRES_PASSWORD is read by docker-compose for the db service default user
POSTGRES_PASSWORD="postgres"

# --- Server ---
NODE_ENV="development"
# HTTP port for node server.js (Next + Socket.io)
PORT="3000"

# --- Optional / future ---
# No cloud API keys are required for core MiniPad behavior.
# NEXTAUTH_* below are placeholders only — this codebase does not ship NextAuth wired by default.
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="http://localhost:3000"
